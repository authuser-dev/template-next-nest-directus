{
	"name": "next-nest-directus",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types",
		"test": "pnpm --filter api test && pnpm --filter web test && pnpm --filter @repo/ui test",
		"test:e2e": "pnpm --filter api test:e2e && pnpm --filter web test:e2e",
		"test:ci": "pnpm lint && pnpm check-types && pnpm test && pnpm test:e2e && pnpm --filter cms validate",
		"release": "semantic-release",
		"release:dry": "semantic-release --dry-run",
		"commitlint": "commitlint --edit",
		"lint-staged": "lint-staged",
		"docker:build:api": "docker build --file apps/api/Dockerfile --tag next-nest-directus-api:local .",
		"docker:build:web": "docker build --file apps/web/Dockerfile --tag next-nest-directus-web:local .",
		"docker:build:cms": "docker build --file apps/cms/Dockerfile --tag next-nest-directus-cms:local apps/cms",
		"docker:build": "pnpm docker:build:api && pnpm docker:build:web && pnpm docker:build:cms",
		"prepare": "husky"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^11.0.6",
		"@semantic-release/gitlab": "^13.2.9",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.6",
		"prettier": "^3.7.4",
		"semantic-release": "^24.2.9",
		"turbo": "^2.8.20",
		"typescript": "5.9.2"
	},
	"lint-staged": {
		"*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}": "prettier --write"
	},
	"packageManager": "pnpm@9.0.0",
	"engines": {
		"node": ">=24"
	}
}
